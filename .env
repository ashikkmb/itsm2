# IT Help Desk - Active Directory Configuration
# Copy this file to ".env" and fill in your actual domain controller details.

# Your Domain Controller's LDAP address.
# Use ldap:// for plain (port 389) or ldaps:// for encrypted (port 636, recommended).
# Example: ldap://dc01.nasoa.mil:389
AD_URL=ldap://192.168.1.10:389

# Your AD domain suffix (the part after @ when users type their UPN login).
# Example: nasoa.mil
AD_DOMAIN=nasoa.mil

# The Base Distinguished Name to search for users.
# Example: DC=nasoa,DC=mil
AD_BASE_DN=DC=nasoa,DC=mil

# Port the app runs on (leave as default unless you have a reason to change it)
PORT=3000
